# =============================================================================
# Template for terraform/secrets.auto.tfvars — copy this file:
#
#     cp secrets.auto.tfvars.example secrets.auto.tfvars
#
# then paste the TEAM AWS account's keys into the copy. The copy is gitignored
# (terraform/.gitignore ignores *.tfvars); only this .example template is
# committed. Never put real keys in this file.
#
# If you prefer, you can skip the secrets file entirely and use a named
# profile in ~/.aws/credentials instead (see README) — the secrets file
# simply takes precedence when present.
# =============================================================================

aws_access_key = "AKIA..."
aws_secret_key = "..."
